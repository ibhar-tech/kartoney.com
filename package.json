{
  "name": "kartoney",
  "version": "1.0.0",
  "private": true,
  "description": "Kartoney.com — free Arabic cartoon & anime streaming library (static site generator)",
  "type": "module",
  "scripts": {
    "build": "node src/build.mjs",
    "serve": "node src/serve.mjs",
    "dev": "node src/build.mjs && node src/serve.mjs",
    "images": "node scripts/fetch-images.mjs && node scripts/optimize-images.mjs",
    "webp": "node scripts/optimize-images.mjs",
    "index": "node scripts/gsc-inspect.mjs",
    "index:auth": "node scripts/gsc-auth.mjs",
    "index:status": "node scripts/gsc-status.mjs",
    "bing": "node scripts/bing-submit.mjs",
    "bing:indexnow": "node scripts/bing-submit.mjs --indexnow",
    "bing:quota": "node scripts/bing-submit.mjs --quota",
    "bing:status": "node scripts/bing-status.mjs"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "engines": {
    "node": "20.x"
  }
}
